## 💡 Advanced Usage

### Custom Configuration

```python
from nanoquant import NanoQuantConfig, NanoQuantizer

config = NanoQuantConfig(
    model_name="meta-llama/Llama-2-7b-hf",
    rank=8,                    # Rank for factorization
    bits=1.0,                  # Target bits per parameter
    calib_samples=128,         # Calibration samples
    calib_seq_len=2048,        # Calibration sequence length
    admm_iterations=50,        # ADMM solver iterations
    pre_tune_epochs=8,         # TUNEFP epochs
    post_tune_epochs=8,        # TUNELATENTSTE epochs
    glob_tune_epochs=8,        # TUNESCALESKD epochs
    device="auto",             # auto/cuda/cpu/mps
    output_dir="./outputs",
)

quantizer = NanoQuantizer(config)
```

### Using Different Components

```python
# SVID Decomposition
from nanoquant import svid_decompose, project_to_binary_low_rank

matrix = torch.randn(256, 256)
approximation = svid_decompose(matrix, rank=8)

# Binary Packing
from nanoquant import pack_binary_matrix, unpack_binary_matrix

packed, metadata = pack_binary_matrix(binary_weights)
recovered = unpack_binary_matrix(packed, metadata)

# Custom Kernels
from nanoquant import OptimizedFactorizedLinear

layer = OptimizedFactorizedLinear(
    d_out=2048, d_in=4096, rank=8,
    U_binary=U, V_binary=V, s1=s1, s2=s2,
    packed=True
)
output = layer(input_tensor)
```

