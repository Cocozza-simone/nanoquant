```python
from nanoquant import NanoQuantConfig, NanoQuantizer

config = NanoQuantConfig(
    model_name="meta-llama/Llama-2-7b-hf",
    rank=8,                    # Rango per fattorizzazione
    bits=1.0,                  # Bit target per parametro
    calib_samples=128,         # Campioni calibrazione
    calib_seq_len=2048,        # Lunghezza sequenza calibrazione
    admm_iterations=50,        # Iterazioni solutore ADMM
    pre_tune_epochs=8,         # Epochs TUNEFP
    post_tune_epochs=8,        # Epochs TUNELATENTSTE
    glob_tune_epochs=8,        # Epochs TUNESCALESKD
    device="auto",             # auto/cuda/cpu/mps
